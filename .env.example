# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored -- never commit real secrets.

# Optional: docker-compose project name (container/volume prefix).
# COMPOSE_PROJECT_NAME=application

# Public origin of the whole app. ALL browser traffic goes here; it routes
# /, /api and /auth internally.
#   - Local dev:   http://localhost:8080
#   - Production:  https://your-domain.com   (no port; served by the Caddy edge)
APP_PUBLIC_BASE_URL=http://localhost:8080

# ---- Production deployment (only used by docker-compose.prod.yml) ----
# Caddy provisions a free Let's Encrypt TLS certificate for APP_DOMAIN. The
# domain's DNS must point at the server and ports 80/443 must be reachable.
# Set APP_PUBLIC_BASE_URL above to https://${APP_DOMAIN} when deploying.
# APP_DOMAIN=your-domain.com
# ACME_EMAIL=you@example.com

# ---- Application database ----
APP_DB_USER=app_user
APP_DB_PASSWORD=change-me
APP_DB_NAME=app_db

# ---- Keycloak database ----
KC_DB_USER=kc_user
KC_DB_PASSWORD=change-me
KC_DB_NAME=kc_db

# ---- Keycloak bootstrap admin (Keycloak admin console) ----
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me

# ---- Keycloak realm / clients ----
KEYCLOAK_REALM=myrealm
# Realm SSL enforcement. Default "external" = require HTTPS for non-private
# clients (keep this in production). Set to "none" for dev over plain HTTP behind
# a TLS-terminating proxy or forwarded URL. The .devcontainer sets this
# automatically for forwarded-URL dev environments.
# KEYCLOAK_SSL_REQUIRED=external
KEYCLOAK_FRONTEND_CLIENT_ID=frontend
KEYCLOAK_BACKEND_CLIENT_ID=backend
KEYCLOAK_BACKEND_CLIENT_SECRET=change-me

# ---- Optional: payments (set PAYMENTS_PROVIDER=stripe to enable) ----
# PAYMENTS_PROVIDER=none
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
